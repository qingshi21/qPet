<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lumenami.backend.mapper.ChatMessageMapper">

    <resultMap id="ChatMessageResult" type="com.lumenami.backend.model.ChatMessage">
        <id property="id" column="id"/>
        <result property="petId" column="pet_id"/>
        <result property="userId" column="user_id"/>
        <result property="role" column="role"/>
        <result property="content" column="content"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <insert id="insert" parameterType="com.lumenami.backend.model.ChatMessage" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO chat_messages (pet_id, user_id, role, content)
        VALUES (#{petId}, #{userId}, #{role}, #{content})
    </insert>

    <select id="findByPetId" resultMap="ChatMessageResult">
        SELECT * FROM chat_messages WHERE pet_id = #{petId} ORDER BY created_at ASC
    </select>

    <delete id="deleteByPetId">
        DELETE FROM chat_messages WHERE pet_id = #{petId}
    </delete>

</mapper>
