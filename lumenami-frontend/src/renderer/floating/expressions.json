{
  "format": "lumenami-expression-presets",
  "version": 1,
  "description": "表情预设表：emotion 标签 → Live2D 参数组合。AI 返回 emotion 标签，前端查表驱动参数。",

  "defaults": {
    "ParamAngleX": 0,
    "ParamAngleY": 0,
    "ParamAngleZ": 0,
    "ParamCheek": 0,
    "ParamEyeLOpen": 1,
    "ParamEyeLSmile": 0,
    "ParamEyeROpen": 1,
    "ParamEyeRSmile": 0,
    "ParamEyeBallX": 0,
    "ParamEyeBallY": 0,
    "ParamBrowLY": 0,
    "ParamBrowRY": 0,
    "ParamBrowLAngle": 0,
    "ParamBrowRAngle": 0,
    "ParamBrowLForm": 0,
    "ParamBrowRForm": 0,
    "ParamMouthForm": 0,
    "ParamMouthOpenY": 0,
    "ParamBodyAngleX": 0,
    "ParamBodyAngleY": 0,
    "ParamBodyAngleZ": 0
  },

  "expressions": {
    "neutral": {
      "description": "平静/默认",
      "params": {}
    },

    "happy": {
      "description": "开心/高兴",
      "params": {
        "ParamEyeLSmile": 1,
        "ParamEyeRSmile": 1,
        "ParamEyeLOpen": 0.85,
        "ParamEyeROpen": 0.85,
        "ParamMouthForm": 1,
        "ParamMouthOpenY": 0.15,
        "ParamCheek": 0.5,
        "ParamBrowLY": 0.4
      }
    },

    "laugh": {
      "description": "大笑",
      "params": {
        "ParamEyeLSmile": 1,
        "ParamEyeRSmile": 1,
        "ParamEyeLOpen": 0.6,
        "ParamEyeROpen": 0.6,
        "ParamMouthForm": 1,
        "ParamMouthOpenY": 0.7,
        "ParamCheek": 0.7,
        "ParamBrowLY": 0.6
      }
    },

    "sad": {
      "description": "难过/伤心",
      "params": {
        "ParamBrowLY": -0.8,
        "ParamBrowRY": -0.8,
        "ParamBrowLAngle": -0.5,
        "ParamBrowRAngle": -0.5,
        "ParamEyeLOpen": 0.7,
        "ParamEyeROpen": 0.7,
        "ParamMouthForm": -0.6,
        "ParamCheek": 0.2
      }
    },

    "angry": {
      "description": "生气/不满",
      "params": {
        "ParamBrowLY": -1,
        "ParamBrowRY": -1,
        "ParamBrowLAngle": -0.8,
        "ParamBrowRAngle": -0.8,
        "ParamBrowLForm": -0.5,
        "ParamBrowRForm": -0.5,
        "ParamEyeLOpen": 0.8,
        "ParamEyeROpen": 0.8,
        "ParamMouthForm": -0.8,
        "ParamCheek": 0.3
      }
    },

    "surprised": {
      "description": "惊讶/吃惊",
      "params": {
        "ParamEyeLOpen": 1.3,
        "ParamEyeROpen": 1.3,
        "ParamBrowLY": 1,
        "ParamBrowRY": 1,
        "ParamMouthForm": 0.2,
        "ParamMouthOpenY": 0.8,
        "ParamAngleZ": 3
      }
    },

    "shy": {
      "description": "害羞/不好意思",
      "params": {
        "ParamCheek": 1,
        "ParamEyeLOpen": 0.8,
        "ParamEyeROpen": 0.8,
        "ParamEyeBallY": -0.5,
        "ParamMouthForm": 0.3,
        "ParamBrowLY": 0.3,
        "ParamAngleX": -3,
        "ParamAngleZ": -2
      }
    },

    "thinking": {
      "description": "思考/犹豫",
      "params": {
        "ParamBrowLY": 0.5,
        "ParamBrowRY": 0.3,
        "ParamBrowLAngle": 0.3,
        "ParamEyeBallX": 0.8,
        "ParamEyeBallY": 0.5,
        "ParamMouthForm": -0.2,
        "ParamAngleX": 5,
        "AngleY": 3,
        "ParamBodyAngleX": 2
      }
    },

    "embarrassed": {
      "description": "尴尬/为难",
      "params": {
        "ParamCheek": 0.6,
        "ParamBrowLY": -0.3,
        "ParamBrowRY": -0.3,
        "ParamBrowLAngle": 0.2,
        "ParamEyeLOpen": 0.75,
        "ParamEyeROpen": 0.75,
        "ParamMouthForm": -0.4,
        "ParamAngleX": -3
      }
    },

    "excited": {
      "description": "兴奋/激动",
      "params": {
        "ParamEyeLOpen": 1.2,
        "ParamEyeROpen": 1.2,
        "ParamEyeLSmile": 0.5,
        "ParamEyeRSmile": 0.5,
        "ParamBrowLY": 0.8,
        "ParamBrowRY": 0.8,
        "ParamMouthForm": 1,
        "ParamMouthOpenY": 0.5,
        "ParamCheek": 0.6,
        "ParamAngleZ": 2
      }
    },

    "tired": {
      "description": "疲惫/困倦",
      "params": {
        "ParamEyeLOpen": 0.5,
        "ParamEyeROpen": 0.5,
        "ParamBrowLY": -0.4,
        "ParamBrowRY": -0.4,
        "ParamMouthForm": -0.2,
        "ParamMouthOpenY": 0.1,
        "ParamAngleY": -3,
        "ParamBodyAngleY": -2
      }
    },

    "curious": {
      "description": "好奇/感兴趣",
      "params": {
        "ParamEyeLOpen": 1.1,
        "ParamEyeROpen": 1.1,
        "ParamBrowLY": 0.6,
        "ParamBrowRY": 0.6,
        "ParamMouthForm": 0.2,
        "ParamMouthOpenY": 0.15,
        "ParamAngleX": 3,
        "ParamAngleY": 2,
        "ParamBodyAngleX": 3
      }
    },

    "smile": {
      "description": "微笑（比happy轻）",
      "params": {
        "ParamEyeLSmile": 0.5,
        "ParamEyeRSmile": 0.5,
        "ParamMouthForm": 0.6,
        "ParamCheek": 0.3
      }
    },

    "cry": {
      "description": "哭泣",
      "params": {
        "ParamBrowLY": -1,
        "ParamBrowRY": -1,
        "ParamBrowLAngle": -0.7,
        "ParamBrowRAngle": -0.7,
        "ParamEyeLOpen": 0.5,
        "ParamEyeROpen": 0.5,
        "ParamMouthForm": -0.8,
        "ParamMouthOpenY": 0.3,
        "ParamCheek": 0.8
      }
    },

    "confused": {
      "description": "困惑/不解",
      "params": {
        "ParamBrowLY": 0.4,
        "ParamBrowRY": -0.2,
        "ParamBrowLAngle": 0.5,
        "ParamBrowRAngle": -0.3,
        "ParamEyeLOpen": 0.9,
        "ParamEyeROpen": 0.85,
        "ParamMouthForm": -0.3,
        "ParamAngleX": -4,
        "ParamAngleZ": -2
      }
    },

    "proud": {
      "description": "得意/自豪",
      "params": {
        "ParamEyeLSmile": 0.7,
        "ParamEyeRSmile": 0.7,
        "ParamEyeLOpen": 0.9,
        "ParamEyeROpen": 0.9,
        "ParamBrowLY": 0.3,
        "ParamMouthForm": 0.8,
        "ParamCheek": 0.4,
        "ParamAngleZ": 3,
        "ParamBodyAngleZ": -2
      }
    },

    "worried": {
      "description": "担心/焦虑",
      "params": {
        "ParamBrowLY": -0.6,
        "ParamBrowRY": -0.6,
        "ParamBrowLAngle": -0.3,
        "ParamBrowRAngle": -0.3,
        "ParamEyeLOpen": 0.85,
        "ParamEyeROpen": 0.85,
        "ParamEyeBallX": -0.5,
        "ParamMouthForm": -0.5,
        "ParamAngleX": -2
      }
    },

    "sleepy": {
      "description": "犯困/想睡觉",
      "params": {
        "ParamEyeLOpen": 0.3,
        "ParamEyeROpen": 0.3,
        "ParamBrowLY": -0.5,
        "ParamBrowRY": -0.5,
        "ParamMouthOpenY": 0.15,
        "ParamMouthForm": -0.1,
        "ParamAngleY": -5,
        "ParamBodyAngleY": -3
      }
    },

    "love": {
      "description": "喜欢/心动",
      "params": {
        "ParamEyeLSmile": 0.8,
        "ParamEyeRSmile": 0.8,
        "ParamEyeLOpen": 0.9,
        "ParamEyeROpen": 0.9,
        "ParamMouthForm": 0.7,
        "ParamCheek": 1,
        "ParamBrowLY": 0.5,
        "ParamAngleZ": 2
      }
    }
  }
}
